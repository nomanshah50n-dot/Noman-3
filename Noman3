<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shah Hospital — Malegaon</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0b2545;
  --navy-mid: #13315c;
  --blue: #1b4f8a;
  --sky: #2e86de;
  --sky-light: #a8d5f7;
  --teal: #00a896;
  --teal-light: #e0f7f5;
  --gold: #f4a629;
  --cream: #f7f9fc;
  --white: #ffffff;
  --gray: #6b7a8d;
  --border: #dde4ee;
  --dark: #0d1b2a;
  --shadow: 0 4px 24px rgba(11,37,69,0.10);
  --shadow-lg: 0 12px 48px rgba(11,37,69,0.16);
  --radius: 16px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Outfit', sans-serif;
  background: var(--cream);
  color: var(--dark);
}

/* ── HEADER ── */
header {
  background: var(--navy);
  position: sticky; top: 0; z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.2);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.logo { display: flex; align-items: center; gap: 12px; }
.logo-icon {
  width: 44px; height: 44px;
  background: var(--teal);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
}
.logo-text h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  line-height: 1;
}
.logo-text h1 span { color: var(--gold); }
.logo-text p { font-size: 0.7rem; color: var(--sky-light); font-weight: 300; letter-spacing: 1px; text-transform: uppercase; margin-top: 1px; }

.header-actions { display: flex; align-items: center; gap: 12px; }
.emergency-pill {
  background: #e53e3e;
  color: white;
  border-radius: 50px;
  padding: 6px 14px;
  font-size: 0.78rem;
  font-weight: 600;
  display: flex; align-items: center; gap: 6px;
  text-decoration: none;
  transition: background 0.2s;
  white-space: nowrap;
}
.emergency-pill:hover { background: #c53030; }
.emergency-pill::before { content: '🚨'; font-size: 0.85rem; }

.nav-links { display: flex; gap: 4px; }
.nav-link {
  background: none; border: none;
  color: rgba(255,255,255,0.75);
  font-family: 'Outfit', sans-serif;
  font-size: 0.85rem;
  font-weight: 500;
  padding: 7px 14px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.18s;
  white-space: nowrap;
}
.nav-link:hover { background: rgba(255,255,255,0.1); color: white; }

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 50%, #0e3d6e 100%);
  color: white;
  padding: 64px 28px 80px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 420px; height: 420px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,168,150,0.18) 0%, transparent 70%);
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -40px;
  width: 300px; height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46,134,222,0.15) 0%, transparent 70%);
}
.hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: center;
  position: relative;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(0,168,150,0.2);
  border: 1px solid rgba(0,168,150,0.4);
  border-radius: 50px;
  padding: 5px 14px;
  font-size: 0.75rem;
  font-weight: 600;
  color: #5de8d5;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.hero h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 14px;
}
.hero h2 em { color: var(--gold); font-style: normal; }
.hero p {
  font-size: 1rem;
  color: rgba(255,255,255,0.78);
  max-width: 500px;
  line-height: 1.6;
  margin-bottom: 28px;
  font-weight: 300;
}
.hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
.btn-primary {
  background: var(--teal);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 13px 26px;
  font-family: 'Outfit', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  display: flex; align-items: center; gap: 8px;
}
.btn-primary:hover { background: #009688; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,168,150,0.35); }
.btn-outline {
  background: transparent;
  color: white;
  border: 1.5px solid rgba(255,255,255,0.35);
  border-radius: 12px;
  padding: 13px 26px;
  font-family: 'Outfit', sans-serif;
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  display: flex; align-items: center; gap: 8px;
}
.btn-outline:hover { background: rgba(255,255,255,0.1); border-color: white; }

.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 14px;
  align-items: flex-end;
}
.stat-card {
  background: rgba(255,255,255,0.09);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 14px;
  padding: 16px 22px;
  text-align: center;
  min-width: 110px;
  backdrop-filter: blur(8px);
}
.stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
}
.stat-label { font-size: 0.72rem; color: rgba(255,255,255,0.65); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.5px; }

/* ── QUICK ACTIONS ── */
.quick-actions {
  background: white;
  border-bottom: 1px solid var(--border);
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.quick-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 28px;
  display: flex;
  overflow-x: auto;
  scrollbar-width: none;
}
.quick-inner::-webkit-scrollbar { display: none; }
.quick-btn {
  display: flex; align-items: center; gap: 8px;
  padding: 16px 22px;
  border: none; background: none;
  font-family: 'Outfit', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--gray);
  cursor: pointer;
  white-space: nowrap;
  border-bottom: 3px solid transparent;
  transition: all 0.18s;
}
.quick-btn:hover, .quick-btn.active {
  color: var(--blue);
  border-bottom-color: var(--teal);
}
.quick-btn .qicon { font-size: 1.1rem; }

/* ── MAIN ── */
.main { max-width: 1200px; margin: 0 auto; padding: 40px 20px 80px; }

.section-header {
  margin-bottom: 28px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--navy);
}
.section-sub {
  font-size: 0.88rem;
  color: var(--gray);
  margin-top: 4px;
}

/* Doctors grid */
.doctors-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 22px;
}

.doctor-card {
  background: white;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: box-shadow 0.25s, transform 0.22s;
  display: flex;
  flex-direction: column;
  animation: fadeUp 0.4s ease both;
  border: 1px solid var(--border);
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.doctor-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-4px); }

.doctor-img-wrap {
  position: relative;
  height: 180px;
  background: linear-gradient(135deg, #e8f4fd, #d0eaf8);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.doctor-img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.doctor-avatar {
  width: 90px; height: 90px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--blue), var(--teal));
  display: flex; align-items: center; justify-content: center;
  font-size: 2.5rem;
  color: white;
  font-weight: 700;
  font-family: 'Cormorant Garamond', serif;
}
.avail-badge {
  position: absolute;
  top: 12px; right: 12px;
  background: #48bb78;
  color: white;
  font-size: 0.68rem;
  font-weight: 600;
  padding: 3px 9px;
  border-radius: 50px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.dept-tag {
  position: absolute;
  bottom: 10px; left: 10px;
  background: var(--navy);
  color: white;
  font-size: 0.68rem;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 6px;
  letter-spacing: 0.3px;
}

.doctor-body { padding: 18px 18px 20px; flex: 1; display: flex; flex-direction: column; }
.doctor-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 3px;
}
.doctor-spec {
  font-size: 0.78rem;
  color: var(--teal);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}
.doctor-desc {
  font-size: 0.82rem;
  color: var(--gray);
  line-height: 1.5;
  flex: 1;
  margin-bottom: 14px;
}
.doctor-footer {
  display: flex; align-items: center; justify-content: space-between; gap: 8px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
}
.doctor-fee {
  display: flex; flex-direction: column;
}
.fee-label { font-size: 0.68rem; color: var(--gray); text-transform: uppercase; letter-spacing: 0.4px; }
.fee-amt {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--navy);
}
.fee-amt span { font-size: 0.75rem; color: var(--gray); font-weight: 400; font-family: 'Outfit', sans-serif; }

.book-btn {
  background: var(--blue);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 10px 18px;
  font-family: 'Outfit', sans-serif;
  font-size: 0.83rem;
  font-weight: 600;
  cursor: pointer;
  display: flex; align-items: center; gap: 6px;
  transition: all 0.18s;
  white-space: nowrap;
}
.book-btn:hover { background: var(--sky); transform: scale(1.03); }

/* ── WHY US ── */
.why-section {
  background: var(--navy);
  color: white;
  padding: 56px 28px;
  margin: 48px 0 0;
}
.why-inner { max-width: 1200px; margin: 0 auto; }
.why-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
}
.why-sub { text-align: center; color: rgba(255,255,255,0.6); font-size: 0.9rem; margin-bottom: 36px; }
.why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
}
.why-card {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 14px;
  padding: 24px 20px;
  text-align: center;
  transition: background 0.2s;
}
.why-card:hover { background: rgba(255,255,255,0.12); }
.why-icon { font-size: 2rem; margin-bottom: 10px; }
.why-card h4 { font-size: 0.95rem; font-weight: 600; margin-bottom: 6px; }
.why-card p { font-size: 0.78rem; color: rgba(255,255,255,0.6); line-height: 1.5; }

/* ── APPOINTMENT MODAL ── */
.overlay {
  position: fixed; inset: 0;
  background: rgba(11,37,69,0.6);
  z-index: 200;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s;
  backdrop-filter: blur(4px);
}
.overlay.open { opacity: 1; pointer-events: all; }

.appt-modal {
  position: fixed; inset: 0;
  z-index: 201;
  display: flex; align-items: center; justify-content: center;
  padding: 20px;
  pointer-events: none;
}
.appt-box {
  background: white;
  border-radius: 20px;
  width: 100%;
  max-width: 500px;
  max-height: 92vh;
  overflow-y: auto;
  box-shadow: 0 30px 80px rgba(0,0,0,0.25);
  transform: scale(0.94) translateY(16px);
  transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1);
  pointer-events: none;
}
.appt-modal.open .appt-box {
  transform: scale(1) translateY(0);
  pointer-events: all;
}

.appt-header {
  background: linear-gradient(135deg, var(--navy), var(--blue));
  color: white;
  padding: 22px 24px;
  border-radius: 20px 20px 0 0;
  display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
}
.appt-header-text h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 700;
}
.appt-header-text p { font-size: 0.8rem; opacity: 0.75; margin-top: 2px; }
.doc-preview {
  background: rgba(255,255,255,0.15);
  border-radius: 10px;
  padding: 8px 14px;
  text-align: right;
  flex-shrink: 0;
}
.doc-preview .pname { font-weight: 700; font-size: 0.88rem; }
.doc-preview .pfee { font-size: 0.75rem; opacity: 0.8; margin-top: 1px; }
.close-btn {
  background: rgba(255,255,255,0.18);
  border: none; border-radius: 50%;
  width: 32px; height: 32px;
  color: white; font-size: 1rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.18s;
  flex-shrink: 0;
}
.close-btn:hover { background: rgba(255,255,255,0.3); }

.appt-body { padding: 24px; }
.form-group { margin-bottom: 16px; }
.form-group label {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 11px 14px;
  font-family: 'Outfit', sans-serif;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.18s, box-shadow 0.18s;
  background: white;
  color: var(--dark);
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--sky);
  box-shadow: 0 0 0 3px rgba(46,134,222,0.12);
}
.form-group textarea { resize: vertical; min-height: 72px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

.form-divider {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--gray);
  margin: 20px 0 14px;
  display: flex; align-items: center; gap: 10px;
}
.form-divider::before, .form-divider::after {
  content: ''; flex: 1; height: 1px;
  background: var(--border);
}

.modal-actions { display: flex; gap: 10px; margin-top: 20px; }
.btn-cancel {
  flex: 1; padding: 12px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: white;
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s;
  color: var(--dark);
}
.btn-cancel:hover { background: #f1f5f9; }

.btn-whatsapp {
  flex: 1; padding: 12px;
  background: #25d366;
  color: white; border: none;
  border-radius: 10px;
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 7px;
  transition: background 0.18s;
}
.btn-whatsapp:hover { background: #1fb855; }
.btn-email {
  flex: 1; padding: 12px;
  background: var(--blue);
  color: white; border: none;
  border-radius: 10px;
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 7px;
  transition: background 0.18s;
}
.btn-email:hover { background: var(--sky); }

/* ── TOAST ── */
.toast {
  position: fixed;
  bottom: 28px; left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--navy);
  color: white;
  padding: 12px 26px;
  border-radius: 50px;
  font-size: 0.88rem;
  font-weight: 500;
  z-index: 500;
  transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
  white-space: nowrap;
  box-shadow: 0 8px 28px rgba(0,0,0,0.2);
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* ── FOOTER ── */
footer {
  background: var(--dark);
  color: rgba(255,255,255,0.65);
  padding: 40px 28px;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 32px;
}
footer h4 {
  font-family: 'Cormorant Garamond', serif;
  color: white;
  font-size: 1.1rem;
  margin-bottom: 12px;
}
footer p { font-size: 0.83rem; line-height: 1.7; }
footer a { color: var(--sky-light); text-decoration: none; }
footer a:hover { color: white; }
.footer-bottom {
  text-align: center;
  margin-top: 32px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.1);
  font-size: 0.75rem;
  opacity: 0.5;
}

/* No results */
.no-results {
  grid-column: 1/-1;
  text-align: center;
  padding: 60px 20px;
  color: var(--gray);
}

/* Search */
.search-wrap {
  position: relative;
  max-width: 340px;
}
.search-wrap input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 50px;
  padding: 9px 16px 9px 40px;
  font-family: 'Outfit', sans-serif;
  font-size: 0.88rem;
  outline: none;
  background: white;
  transition: border-color 0.18s;
}
.search-wrap input:focus { border-color: var(--sky); }
.search-wrap::before {
  content: '🔍';
  position: absolute;
  left: 13px; top: 50%;
  transform: translateY(-50%);
  font-size: 0.85rem;
  pointer-events: none;
}

/* Responsive */
@media (max-width: 768px) {
  .header-inner { padding: 12px 16px; }
  .nav-links { display: none; }
  .hero-inner { grid-template-columns: 1fr; }
  .hero-stats { flex-direction: row; align-items: flex-start; }
  .stat-card { min-width: 90px; }
  .hero { padding: 40px 16px 52px; }
  .main { padding: 28px 14px 60px; }
  .doctors-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
  .footer-inner { grid-template-columns: 1fr; gap: 24px; }
  .form-row { grid-template-columns: 1fr; }
  .modal-actions { flex-direction: column; }
}
@media (max-width: 480px) {
  .doctors-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .doctor-body { padding: 12px 12px 14px; }
  .doctor-name { font-size: 0.95rem; }
}
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-inner">
    <div class="logo">
      <div class="logo-icon">🏥</div>
      <div class="logo-text">
        <h1>Shah <span>Hospital</span></h1>
        <p>Health is Wealth · Malegaon</p>
      </div>
    </div>
    <div class="header-actions">
      <div class="nav-links">
        <button class="nav-link" onclick="scrollTo(0,0)">Home</button>
        <button class="nav-link" onclick="document.getElementById('doctors').scrollIntoView({behavior:'smooth'})">Doctors</button>
        <button class="nav-link" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Contact</button>
      </div>
      <a href="tel:9999999999" class="emergency-pill">Emergency: 9999999999</a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">✦ Trusted Care Since 2001</div>
      <h2>Your Health is Our<br><em>Top Priority</em></h2>
      <p>Book appointments with our specialist doctors online — quick, easy, and free. Expert medical care delivered with compassion in Malegaon.</p>
